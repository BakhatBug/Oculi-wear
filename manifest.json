{
  "manifest_version": 3,
  "name": "Sleep Cycle Optimizer",
  "version": "1.1.0",
  "description": "Bedtime reminders, eye protection, break alerts, and tab dimming for healthier sleep.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "scripting",
    "notifications",
    "idle"
  ],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "toggle-eye-protection": {
      "suggested_key": { "default": "Alt+Shift+E" },
      "description": "Toggle Eye Protection Mode"
    },
    "toggle-dimming": {
      "suggested_key": { "default": "Alt+Shift+D" },
      "description": "Toggle Bedtime Dimming"
    }
  },
  "background": {
    "service_worker": "background/worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/dimmer.js"],
      "css": ["content/dimmer.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
